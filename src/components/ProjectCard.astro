---
/** ProjectCard — 作品集卡片 */

interface Props {
  title: string;
  description: string;
  tech: string[];
  url?: string;
  repo?: string;
  status: string;
  class?: string;
}

const { title, description, tech, url, repo, status, class: className } = Astro.props;

const statusLabels: Record<string, string> = {
  active: '维护中',
  archived: '已归档',
  wip: '开发中',
};
---

<article class:list={['project-card', className]}>
  <h3 class="project-title">
    {url ? <a href={url}>{title}</a> : title}
  </h3>
  <span class="project-status" data-status={status}>{statusLabels[status]}</span>
  <p class="project-desc">{description}</p>
  {tech.length > 0 && (
    <div class="project-tech">
      {tech.map((t) => <span class="tech-tag">{t}</span>)}
    </div>
  )}
  {repo && (
    <a href={repo} class="project-repo" target="_blank" rel="noopener">源码</a>
  )}
</article>

<style>
  .project-card {
    padding: var(--space-6);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    background: var(--color-bg-secondary);
  }

  .project-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
  }

  .project-title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .project-title a:hover {
    color: var(--color-accent);
  }

  .project-status {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    background: var(--color-bg-tertiary);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-3);
    display: inline-block;
  }

  .project-status[data-status="active"] {
    color: #2d7d46;
    background: #e6f4ea;
  }

  .project-status[data-status="wip"] {
    color: #b45309;
    background: #fef3c7;
  }

  .project-desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
    line-height: var(--leading-normal);
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .tech-tag {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    background: var(--color-bg-tertiary);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
  }

  .project-repo {
    font-size: var(--text-sm);
    color: var(--color-accent);
  }
</style>
