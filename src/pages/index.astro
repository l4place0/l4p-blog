---
/** 首页 — Hero + 精选文章 + 最近文章 */

import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';

const isDev = import.meta.env.DEV;
const allPosts = await getCollection('blog', ({ data }) => isDev || !data.draft);
const sorted = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featured = sorted.filter((p) => p.data.featured);
const recent = sorted.slice(0, 5);
---

<BaseLayout title="l4.place" description="写一些东西，留住一些东西。">
  <section class="hero">
    <h1 class="hero-title">l4.place</h1>
    <p class="hero-tagline">写一些东西，留住一些东西。</p>
  </section>

  {featured.length > 0 && (
    <section class="section">
      <h2 class="section-title">精选</h2>
      <div class="divider"></div>
      {featured.map((post) => <ArticleCard post={post} />)}
    </section>
  )}

  <section class="section">
    <h2 class="section-title">最近</h2>
    <div class="divider"></div>
    {recent.map((post) => <ArticleCard post={post} />)}
    <a href="/blog/" class="view-all">查看全部文章 &rarr;</a>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: var(--space-24) 0 var(--space-16);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    letter-spacing: var(--tracking-wider);
    margin-bottom: var(--space-4);
  }

  .hero-tagline {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .section {
    margin-bottom: var(--space-16);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-2);
  }

  .divider {
    width: 3rem;
    height: 1px;
    background: var(--color-accent-muted);
    margin-bottom: var(--space-6);
  }

  .view-all {
    display: inline-block;
    margin-top: var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-accent);
    text-decoration: none;
  }

  .view-all:hover {
    color: var(--color-accent-hover);
  }
</style>
