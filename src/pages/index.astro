---
/** 首页 — 站点介绍 + 占位内容 */

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="l4.place" description="复古文艺风格的个人博客">
  <section class="hero">
    <h1 class="hero-title">l4.place</h1>
    <p class="hero-tagline">写一些东西，留住一些东西。</p>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: var(--space-24) 0;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    letter-spacing: var(--tracking-wider);
    margin-bottom: var(--space-4);
  }

  .hero-tagline {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    font-style: italic;
  }
</style>
